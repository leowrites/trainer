{
  "name": "trainer",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "seed:dev": "cross-env EXPO_PUBLIC_DEV_SEED=1 expo start",
    "prebuild": "expo prebuild --no-install",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas:build:ios": "eas build --profile development --platform ios",
    "eas:build:android": "eas build --profile development --platform android",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:perf": "jest src/core/performance/__tests__ src/features/schedule/__tests__/schedule-screens.perf.test.tsx src/features/workout-mode/__tests__/active-workout-profiler.test.tsx src/features/workout-mode/__tests__/workout-screen.test.tsx src/features/workout-mode/__tests__/workout-summary-screen.test.tsx src/features/routines/__tests__/routines-screen.test.tsx src/features/analytics/__tests__/history-screen.test.tsx src/features/analytics/__tests__/history-session-detail-screen.test.tsx src/features/intelligence/__tests__/goals-screen.test.tsx src/features/health-tracking/__tests__/profile-screen.test.tsx src/core/navigation/__tests__/root-navigator.test.tsx",
    "test:perf:ci": "npm run test:perf -- --runInBand --ci",
    "perf:ios:nightly": "node ./scripts/perf/ios-nightly.mjs",
    "perf:baseline:update": "node ./scripts/perf/update-baseline.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/html-elements": "^0.10.1",
    "@gluestack-ui/core": "^3.0.13",
    "@gluestack-ui/utils": "^3.0.15",
    "@legendapp/motion": "^2.5.3",
    "@lodev09/react-native-true-sheet": "^3.9.9",
    "@quidone/react-native-wheel-picker": "^1.6.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "~55.0.5",
    "expo-dev-client": "~55.0.16",
    "expo-haptics": "^55.0.9",
    "expo-linear-gradient": "^55.0.9",
    "expo-notifications": "~55.0.13",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~6.0.9",
    "gluestack-ui": "^3.0.11",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-aria": "^3.47.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-pager-view": "^8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "react-stately": "^3.45.0",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^0.1.20",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~55.0.0",
    "cross-env": "^10.1.0",
    "cspell": "^9.7.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "lint-staged": "^16.3.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "secretlint": "^11.3.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ],
    "*.{md,txt}": [
      "cspell --no-must-find-files"
    ]
  }
}
